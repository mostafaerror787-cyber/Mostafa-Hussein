rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /songs/{userId}/{allPaths=**} {
      // Allow read access to anyone (public music)
      allow read: if true;
      
      // Allow write if the user is authenticated and is the owner of the path
      // OR if the user is an admin
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.email == 'mostafaerror787@gmail.com' ||
        request.auth.token.email == 'mostfaerror787@gmail.com'
      );
    }
  }
}
