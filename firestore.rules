rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == 'mostafaerror787@gmail.com' ||
              request.auth.token.email == 'mostfaerror787@gmail.com'); // Adding common typo just in case
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) {
      return id is string && id.size() <= 256; // More permissive on ID size
    }

    // User Validation
    function isValidUser(data) {
      return (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 200)) &&
             (!('email' in data) || (data.email is string && data.email.size() <= 200));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    // Song Validation - More robust field checks
    function isValidSong(data) {
      return (!('title' in data) || (data.title is string && data.title.size() <= 500)) &&
             (!('artist' in data) || (data.artist is string && data.artist.size() <= 500)) &&
             (!('ownerId' in data) || (data.ownerId is string)) &&
             (!('audioUrl' in data) || (data.audioUrl is string)) &&
             (!('coverUrl' in data) || (data.coverUrl is string)) &&
             (!('isLiked' in data) || (data.isLiked is bool)) &&
             (!('duration' in data) || (data.duration is string)) &&
             (!('genre' in data) || (data.genre is string)) &&
             (!('createdAt' in data) || (data.createdAt is timestamp || data.createdAt == null)) &&
             (!('updatedAt' in data) || (data.updatedAt is timestamp || data.updatedAt == null));
    }

    match /songs/{songId} {
      // Public read access for the library
      allow get: if true;
      allow list: if true; 
      
      allow create: if isValidSong(incoming());

      allow update: if (isAdmin() || 
                       (isSignedIn() && (
                          // Toggling Like (any user)
                          incoming().diff(existing()).affectedKeys().hasOnly(['isLiked']) ||
                          // Updating own song (owner)
                          (incoming().ownerId == request.auth.uid && isValidSong(incoming()))
                       ))) && isValidId(songId);
                    
      allow delete: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }

    // Health check
    match /test/connection {
      allow read: if true;
    }
  }
}
