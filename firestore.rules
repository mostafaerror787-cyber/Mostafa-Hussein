rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'mostafaerror787@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Validation
    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
                      isValidUser(incoming());
    }

    // Song Validation - Improved for compatibility and identity integrity
    function isValidSong(data) {
      return (data.get('title', null) == null || (data.title is string && data.title.size() <= 200)) &&
             (data.get('artist', null) == null || (data.artist is string && data.artist.size() <= 100)) &&
             (data.get('ownerId', null) == null || (data.ownerId is string && data.ownerId.size() <= 128)) &&
             (data.get('duration', null) == null || (data.duration is string && data.duration.size() <= 20)) &&
             (data.get('genre', null) == null || (data.genre is string && data.genre.size() <= 50)) &&
             (data.get('audioUrl', null) == null || (data.audioUrl is string && data.audioUrl.size() <= 1000)) &&
             (data.get('coverUrl', null) == null || (data.coverUrl is string && data.coverUrl.size() <= 1000)) &&
             (data.get('userId', null) == null || (data.userId is string && data.userId.size() <= 128)) &&
             (data.get('isLiked', null) == null || data.isLiked is bool) &&
             (data.get('createdAt', null) == null || data.createdAt is timestamp) &&
             (data.get('updatedAt', null) == null || data.updatedAt is timestamp);
    }

    match /songs/{songId} {
      // Evaluation based access for public lists
      allow list: if resource.data.title is string; 
      allow get: if true;
      
      allow create: if (isAdmin() || (isSignedIn() && incoming().ownerId == request.auth.uid)) && 
                    isValidSong(incoming()) &&
                    incoming().createdAt == request.time &&
                    isValidId(songId);

      allow update: if (isAdmin() || (isSignedIn() && incoming().ownerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isLiked']))) && 
                    isValidSong(incoming()) &&
                    isValidId(songId);
                    
      allow delete: if isAdmin() && isValidId(songId);
    }

    // Health check
    match /test/connection {
      allow read: if true;
    }
  }
}
