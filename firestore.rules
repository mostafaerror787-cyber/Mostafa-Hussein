rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Validation
    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']) &&
                      isValidUser(incoming());
    }

    // Song Validation
    function isValidSong(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.artist is string && data.artist.size() <= 100 &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.duration is string && data.duration.size() <= 20 &&
             data.genre is string && data.genre.size() <= 50 &&
             (data.coverUrl == null || (data.coverUrl is string && data.coverUrl.size() <= 500)) &&
             (data.get('isLiked', null) == null || data.isLiked is bool) &&
             data.createdAt is timestamp &&
             (data.get('updatedAt', null) == null || data.updatedAt is timestamp);
    }

    match /songs/{songId} {
      allow get: if isSignedIn() && existing().ownerId == request.auth.uid && isValidId(songId);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                    incoming().ownerId == request.auth.uid &&
                    isValidSong(incoming()) &&
                    incoming().createdAt == request.time &&
                    isValidId(songId);

      allow update: if isSignedIn() && 
                    existing().ownerId == request.auth.uid &&
                    isValidSong(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    isValidId(songId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['title', 'artist', 'genre', 'coverUrl', 'updatedAt', 'isLiked']);
                    
      allow delete: if isSignedIn() && (existing().get('ownerId', '') == request.auth.uid || !('ownerId' in existing()));
    }
  }
}
